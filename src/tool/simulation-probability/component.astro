---
import "./SimulationProbability.css";

interface Props {
  ui: {
    simulationParameters: string;
    fpLabel: string;
    fpSub: string;
    flLabel: string;
    flSub: string;
    fiLabel: string;
    fiSub: string;
    nLabel: string;
    nSub: string;
    probabilityTitle: string;
    trilemmaResult: string;
    scenario1: string;
    scenario2: string;
    scenario3: string;
  };
}

const { ui } = Astro.props;
---

<div 
  class="simulation-app" 
  id="simulation-app"
  data-ui-scenario1={ui.scenario1}
  data-ui-scenario2={ui.scenario2}
  data-ui-scenario3={ui.scenario3}
>
  <div class="simulation-card">
    <div class="simulation-grid">
      <div class="params-column">
        <h2 class="section-title">{ui.simulationParameters}</h2>
        
        <div class="param-card">
          <div class="param-header">
            <span class="param-symbol">{ui.fpLabel}</span>
            <span class="param-desc">{ui.fpSub}</span>
            <span id="fp-val" class="param-value">50%</span>
          </div>
          <input type="range" id="fp-range" min="1" max="100" value="50" class="sim-slider" />
        </div>

        <div class="param-card">
          <div class="param-header">
            <span class="param-symbol">{ui.flLabel}</span>
            <span class="param-desc">{ui.flSub}</span>
            <span id="fl-val" class="param-value">50%</span>
          </div>
          <input type="range" id="fl-range" min="1" max="100" value="50" class="sim-slider" />
        </div>

        <div class="param-card">
          <div class="param-header">
            <span class="param-symbol">{ui.fiLabel}</span>
            <span class="param-desc">{ui.fiSub}</span>
            <span id="fi-val" class="param-value">10%</span>
          </div>
          <input type="range" id="fi-range" min="1" max="100" value="10" class="sim-slider" />
        </div>

        <div class="param-card">
          <div class="param-header">
            <span class="param-symbol">{ui.nLabel}</span>
            <span class="param-desc">{ui.nSub}</span>
            <span id="n-val" class="param-value">1000</span>
          </div>
          <input type="range" id="n-range" min="1" max="1000000" step="1000" value="1000" class="sim-slider" />
        </div>
      </div>

      <div class="results-column">
        <div class="main-result-card">
          <h3 class="result-label">{ui.probabilityTitle}</h3>
          <div class="result-value"><span id="prob-total">0</span><small>%</small></div>
          <div class="prob-bar-container">
            <div id="prob-bar-fill" class="prob-bar-fill" style="width: 0%"></div>
          </div>
        </div>

        <div class="verdict-card">
          <h4 class="verdict-title">{ui.trilemmaResult}</h4>
          <div class="scenarios-stack">
            <div id="scen-1" class="scenario-item">
              <div class="scenario-dot"></div>
              <span class="scenario-text">{ui.scenario1}</span>
              <span class="scenario-percent" id="p1-val">0%</span>
            </div>
            <div id="scen-2" class="scenario-item">
              <div class="scenario-dot"></div>
              <span class="scenario-text">{ui.scenario2}</span>
              <span class="scenario-percent" id="p2-val">0%</span>
            </div>
            <div id="scen-3" class="scenario-item active">
              <div class="scenario-dot"></div>
              <span class="scenario-text">{ui.scenario3}</span>
              <span class="scenario-percent" id="p3-val">0%</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  const app = document.getElementById('simulation-app');
  
  const fpRange = document.getElementById('fp-range');
  const flRange = document.getElementById('fl-range');
  const fiRange = document.getElementById('fi-range');
  const nRange = document.getElementById('n-range');

  const fpVal = document.getElementById('fp-val');
  const flVal = document.getElementById('fl-val');
  const fiVal = document.getElementById('fi-val');
  const nVal = document.getElementById('n-val');

  const probTotal = document.getElementById('prob-total');
  const probBarFill = document.getElementById('prob-bar-fill');
  const p1Val = document.getElementById('p1-val');
  const p2Val = document.getElementById('p2-val');
  const p3Val = document.getElementById('p3-val');

  function update() {
    const fp = fpRange.value / 100;
    const fl = flRange.value / 100;
    const fi = fiRange.value / 100;
    const n = parseInt(nRange.value);

    fpVal.innerText = Math.round(fp * 100) + '%';
    flVal.innerText = Math.round(fl * 100) + '%';
    fiVal.innerText = Math.round(fi * 100) + '%';
    nVal.innerText = n.toLocaleString();

    const p1 = 1 - (fp * fl);
    const p2 = (fp * fl) * (1 - fi);
    const p3 = (fp * fl * fi * n) / (fp * fl * fi * n + 1);

    const probSim = (p3 * 100).toFixed(4);

    probTotal.innerText = parseFloat(probSim).toLocaleString();
    probBarFill.style.width = probSim + '%';

    p1Val.innerText = Math.round(p1 * 100) + '%';
    p2Val.innerText = Math.round(p2 * 100) + '%';
    p3Val.innerText = Math.round(p3 * 100) + '%';

    document.querySelectorAll('.scenario-item').forEach(el => el.classList.remove('active'));
    if (p1 > p2 && p1 > p3) document.getElementById('scen-1').classList.add('active');
    else if (p2 > p3) document.getElementById('scen-2').classList.add('active');
    else document.getElementById('scen-3').classList.add('active');
  }

  [fpRange, flRange, fiRange, nRange].forEach(r => r?.addEventListener('input', update));
  update();
</script>
