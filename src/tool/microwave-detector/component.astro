---
import "./MicrowaveDetector.css";
import { Icon } from "astro-icon/components";

interface Props {
  ui: {
    microwaveDetection: string;
    shieldingAnalysis: string;
    startTest: string;
    stopTest: string;
    waitingForStart: string;
    detectingInterference: string;
    baseLevel: string;
    activeLevel: string;
    leakProbability: string;
    lowLeak: string;
    mediumLeak: string;
    highLeak: string;
    pingLabel: string;
    packetLossLabel: string;
  };
}

const { ui } = Astro.props;
---

<div 
  class="microwave-app" 
  id="microwave-app"
  data-ui-low={ui.lowLeak}
  data-ui-medium={ui.mediumLeak}
  data-ui-high={ui.highLeak}
  data-ui-start={ui.startTest}
  data-ui-stop={ui.stopTest}
  data-ui-waiting={ui.waitingForStart}
  data-ui-detecting={ui.detectingInterference}
>
  <div class="microwave-card">
    <div class="microwave-header">
      <div class="microwave-title-group">
        <div class="microwave-icon-pulse">
          <Icon name="mdi:molecule" class="w-8 h-8 text-primary-500" />
        </div>
        <div>
          <h2 class="microwave-tool-name">{ui.microwaveDetection}</h2>
          <p class="microwave-tool-desc">{ui.shieldingAnalysis}</p>
        </div>
      </div>
      <button id="test-btn" class="microwave-test-btn">
        <Icon name="mdi:play" class="w-5 h-5" id="btn-icon" />
        <span id="btn-text">{ui.startTest}</span>
      </button>
    </div>

    <div class="microwave-grid">
      <div class="microwave-chart-panel">
        <div class="chart-header">
          <div class="status-indicator">
            <div id="status-dot" class="dot"></div>
            <span id="status-text">{ui.waitingForStart}</span>
          </div>
          <div class="latency-badge">
            <span id="current-ping">0</span> ms
          </div>
        </div>
        <div class="chart-container">
          <canvas id="interference-chart"></canvas>
        </div>
      </div>

      <div class="microwave-data-panel">
        <div class="data-group">
          <div class="data-card">
            <span class="data-label">{ui.baseLevel}</span>
            <div class="data-value"><span id="base-ping">--</span> <small>ms</small></div>
          </div>
          <div class="data-card highlighted">
            <span class="data-label">{ui.activeLevel}</span>
            <div class="data-value"><span id="active-ping">--</span> <small>ms</small></div>
          </div>
        </div>

        <div class="probability-card">
          <div class="prob-header">
            <span class="prob-label">{ui.leakProbability}</span>
            <span id="leak-status" class="prob-status status-low">{ui.lowLeak}</span>
          </div>
          <div class="prob-bar-bg">
            <div id="prob-bar-fill" class="prob-bar-fill" style="width: 0%"></div>
          </div>
          <p class="prob-desc">Basado en jitter y pérdida de paquetes detectada.</p>
        </div>

        <div class="stats-list">
          <div class="stat-item">
            <span class="stat-name">{ui.pingLabel}</span>
            <span id="stat-latency" class="stat-val">--</span>
          </div>
          <div class="stat-item">
            <span class="stat-name">{ui.packetLossLabel}</span>
            <span id="stat-loss" class="stat-val">0%</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  const app = document.getElementById('microwave-app');
  const labels = {
    low: app?.getAttribute('data-ui-low') || 'Low',
    medium: app?.getAttribute('data-ui-medium') || 'Medium',
    high: app?.getAttribute('data-ui-high') || 'High',
    start: app?.getAttribute('data-ui-start') || 'Start',
    stop: app?.getAttribute('data-ui-stop') || 'Stop',
    waiting: app?.getAttribute('data-ui-waiting') || 'Waiting...',
    detecting: app?.getAttribute('data-ui-detecting') || 'Detecting...'
  };

  let isRunning = false;
  let basePing = 0;
  let pings = [];
  const maxDataPoints = 40;
  let interval;

  const canvas = document.getElementById("interference-chart");
  const ctx = canvas.getContext("2d");
  const testBtn = document.getElementById("test-btn");
  const btnText = document.getElementById("btn-text");
  const statusText = document.getElementById("status-text");
  const statusDot = document.getElementById("status-dot");
  const currentPingEl = document.getElementById("current-ping");
  const basePingEl = document.getElementById("base-ping");
  const activePingEl = document.getElementById("active-ping");
  const leakStatusEl = document.getElementById("leak-status");
  const probBarFill = document.getElementById("prob-bar-fill");

  function drawChart() {
    if (!ctx) return;
    const w = canvas.width = canvas.parentElement.clientWidth;
    const h = canvas.height = canvas.parentElement.clientHeight;

    ctx.clearRect(0, 0, w, h);
    
    ctx.strokeStyle = "rgba(100, 116, 139, 0.1)";
    ctx.lineWidth = 1;
    for(let i=0; i<5; i++) {
      const y = h - (h/4 * i);
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(w, y);
      ctx.stroke();
    }

    if (pings.length < 2) return;

    const step = w / (maxDataPoints - 1);
    const maxVal = Math.max(...pings, 100);

    ctx.beginPath();
    ctx.strokeStyle = "#8b5cf6";
    ctx.lineWidth = 3;
    ctx.lineJoin = "round";

    pings.forEach((p, i) => {
      const x = i * step;
      const y = h - (p / maxVal * h);
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    });
    ctx.stroke();

    const gradient = ctx.createLinearGradient(0, 0, 0, h);
    gradient.addColorStop(0, "rgba(139, 92, 246, 0.2)");
    gradient.addColorStop(1, "rgba(139, 92, 246, 0)");
    
    ctx.lineTo((pings.length-1)*step, h);
    ctx.lineTo(0, h);
    ctx.fillStyle = gradient;
    ctx.fill();
  }

  async function measurePing() {
    const start = performance.now();
    try {
      await fetch(window.location.href, { method: 'HEAD', cache: 'no-store' });
      return performance.now() - start;
    } catch {
      return performance.now() - start; 
    }
  }

  async function update() {
    const p = await measurePing();
    pings.push(p);
    if (pings.length > maxDataPoints) pings.shift();

    if (currentPingEl) currentPingEl.innerText = Math.round(p).toString();

    if (isRunning) {
      const avg = pings.slice(-5).reduce((a, b) => a + b, 0) / 5;
      if (activePingEl) activePingEl.innerText = Math.round(avg).toString();

      const diff = avg - basePing;
      let prob = 0;
      let status = labels.low;
      let statusClass = "status-low";

      if (diff > 150) { 
        prob = 90; status = labels.high; statusClass = "status-high"; 
      }
      else if (diff > 50) { 
        prob = 45; status = labels.medium; statusClass = "status-medium"; 
      }
      else if (diff > 10) { 
        prob = 15; status = labels.low; statusClass = "status-low"; 
      }

      if (leakStatusEl) {
        leakStatusEl.innerText = status;
        leakStatusEl.className = `prob-status ${statusClass}`;
      }
      if (probBarFill) probBarFill.style.width = `${prob}%`;
    }

    drawChart();
  }

  testBtn?.addEventListener("click", async () => {
    if (!isRunning) {
      isRunning = true;
      if (btnText) btnText.innerText = labels.stopTest;
      if (statusText) statusText.innerText = labels.detectingInterference;
      statusDot?.classList.add("pulse");
      
      const initialPings = [];
      for(let i=0; i<5; i++) initialPings.push(await measurePing());
      basePing = initialPings.reduce((a, b) => a + b, 0) / 5;
      if (basePingEl) basePingEl.innerText = Math.round(basePing).toString();

      interval = setInterval(update, 500);
    } else {
      isRunning = false;
      if (btnText) btnText.innerText = labels.startTest;
      if (statusText) statusText.innerText = labels.waitingForStart;
      statusDot?.classList.remove("pulse");
      clearInterval(interval);
    }
  });

  window.addEventListener("resize", drawChart);
  drawChart();
</script>
