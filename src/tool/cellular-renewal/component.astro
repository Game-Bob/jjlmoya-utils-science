---
interface Props {
  ui: {
    biologicalTimeline: string;
    ageUnit: string;
    matterNewPercent: string;
    atomicRenewal: string;
    skinAndBlood: string;
    boneRemodeling: string;
    organicMatrix: string;
    perennialCells: string;
    disclaimerText: string;
  };
}

const { ui } = Astro.props;
---

<div class="cellular-app" id="cellular-app">
  <div class="cellular-card">
    <div class="input-section">
      <div class="input-group">
        <div class="input-label">{ui.biologicalTimeline}</div>
        <div class="age-display">
          <span id="ageDisplay">25</span>
          <span class="age-unit">{ui.ageUnit}</span>
        </div>
        <input
          type="range"
          id="ageRange"
          min="1"
          max="105"
          step="1"
          value="25"
          aria-label="Age"
        />
      </div>
    </div>

    <div class="results-grid">
      <div class="main-stat">
        <span class="main-stat-label">{ui.matterNewPercent}</span>
        <div class="main-stat-value">
          <span id="newStatVal">93</span>
          <span class="percent-sign">%</span>
        </div>
        <div class="main-stat-sublabel">{ui.atomicRenewal}</div>
      </div>

      <div class="tissue-list">
        <div class="tissue-item">
          <div class="tissue-header">
            <span class="tissue-name">{ui.skinAndBlood}</span>
            <span class="tissue-percentage" id="skinVal">100%</span>
          </div>
          <div class="bar-container">
            <div class="bar-fill" id="skinBar" style="width: 100%;"></div>
          </div>
        </div>

        <div class="tissue-item">
          <div class="tissue-header">
            <span class="tissue-name">{ui.boneRemodeling}</span>
            <span class="tissue-percentage" id="boneVal">85%</span>
          </div>
          <div class="bar-container">
            <div class="bar-fill" id="boneBar" style="width: 85%;"></div>
          </div>
        </div>

        <div class="tissue-item">
          <div class="tissue-header">
            <span class="tissue-name">{ui.organicMatrix}</span>
            <span class="tissue-percentage" id="organVal">60%</span>
          </div>
          <div class="bar-container">
            <div class="bar-fill" id="organBar" style="width: 60%;"></div>
          </div>
        </div>

        <div class="tissue-item">
          <div class="tissue-header">
            <span class="tissue-name">{ui.perennialCells}</span>
            <span class="tissue-percentage" id="brainVal">12%</span>
          </div>
          <div class="bar-container">
            <div class="bar-fill" id="brainBar" style="width: 12%;"></div>
          </div>
        </div>
      </div>
    </div>

    <p class="disclaimer">
      {ui.disclaimerText}
    </p>
  </div>
</div>

<style is:inline define:vars={{}}>
  :root {
    --cell-primary: #f43f5e;
    --cell-secondary: #8b5cf6;
    --cell-text: #0f172a;
    --cell-text-muted: #475569;
    --cell-bg: #fff;
    --cell-bg-secondary: #f8fafc;
    --cell-bg-tertiary: #f1f5f9;
    --cell-border: #e2e8f0;
    --cell-bar: linear-gradient(90deg, #f43f5e 0%, #8b5cf6 100%);
  }

  .theme-dark {
    --cell-primary: #ff6b7a;
    --cell-secondary: #a78bfa;
    --cell-text: #fff;
    --cell-text-muted: #a0aec0;
    --cell-bg: #0f172a;
    --cell-bg-secondary: #1c1f2e;
    --cell-bg-tertiary: #151720;
    --cell-border: #2d3748;
    --cell-bar: linear-gradient(90deg, #ff6b7a 0%, #a78bfa 100%);
  }

  .cellular-app {
    max-width: 850px;
    margin: 0 auto;
  }

  .cellular-card {
    background: var(--cell-bg);
    border: 1px solid var(--cell-border);
    border-radius: 24px;
    padding: 2rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .theme-dark .cellular-card {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  .input-section {
    margin-bottom: 3.5rem;
  }

  .input-group {
    background: var(--cell-bg-secondary);
    padding: 2rem;
    border-radius: 20px;
    border: 1px solid var(--cell-border);
  }

  .input-label {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--cell-text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
    display: block;
  }

  .age-display {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  #ageDisplay {
    font-size: 3.5rem;
    font-weight: 950;
    color: var(--cell-primary);
    line-height: 1;
  }

  .age-unit {
    font-size: 0.95rem;
    color: var(--cell-primary);
    font-weight: 500;
  }

  input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 10px;
    background: var(--cell-bg-tertiary);
    border-radius: 8px;
    outline: none;
    border: 1px solid var(--cell-border);
  }

  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 24px;
    height: 24px;
    background: var(--cell-primary);
    border: 3px solid var(--cell-bg);
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    transition: transform 0.1s;
  }

  input[type="range"]::-webkit-slider-thumb:active {
    transform: scale(1.2);
  }

  input[type="range"]::-moz-range-thumb {
    width: 24px;
    height: 24px;
    background: var(--cell-primary);
    border: 3px solid var(--cell-bg);
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    transition: transform 0.1s;
  }

  input[type="range"]::-moz-range-thumb:active {
    transform: scale(1.2);
  }

  .results-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  @media (max-width: 640px) {
    .results-grid {
      grid-template-columns: 1fr;
    }
  }

  .main-stat {
    background: var(--cell-bg-secondary);
    padding: 2.5rem;
    border-radius: 20px;
    border: 2px solid var(--cell-primary);
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 280px;
  }

  .main-stat-label {
    font-size: 0.875rem;
    color: var(--cell-text-muted);
    font-weight: 600;
    margin-bottom: 1.5rem;
    line-height: 1.4;
  }

  .main-stat-value {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
  }

  #newStatVal {
    font-size: 5rem;
    font-weight: 950;
    color: var(--cell-primary);
    line-height: 1;
  }

  .percent-sign {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--cell-primary);
  }

  .main-stat-sublabel {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--cell-primary);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .tissue-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .tissue-item {
    background: var(--cell-bg-secondary);
    padding: 1.25rem;
    border-radius: 14px;
    border: 1px solid var(--cell-border);
  }

  .tissue-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .tissue-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--cell-text);
  }

  .tissue-percentage {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--cell-primary);
  }

  .bar-container {
    width: 100%;
    height: 10px;
    background: var(--cell-bg-tertiary);
    border-radius: 5px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    background: var(--cell-bar);
    border-radius: 4px;
    transition: width 0.3s ease;
  }

  .disclaimer {
    font-size: 0.875rem;
    color: #78660b;
    line-height: 1.7;
    padding: 1.5rem;
    background-color: #fef9e7;
    border-radius: 12px;
    border: 1px solid #fce8aa;
    margin: 2.5rem auto 0;
    max-width: 600px;
    text-align: center;
  }

  .theme-dark .disclaimer {
    color: #78660b;
    background-color: #fef9e7;
    border-color: #fce8aa;
  }

  @media (max-width: 640px) {
    .cellular-card {
      padding: 1.5rem;
    }

    #newStatVal {
      font-size: 2.5rem;
    }

    .input-group {
      padding: 1rem;
    }
  }
</style>

<script>
  import { CellularRenewalEngine } from "./logic/CellularRenewalEngine";

  const ageInput = document.getElementById("ageRange") as HTMLInputElement;
  const ageDisplay = document.getElementById("ageDisplay");
  const newStatVal = document.getElementById("newStatVal");
  const skinVal = document.getElementById("skinVal");
  const skinBar = document.getElementById("skinBar");
  const boneVal = document.getElementById("boneVal");
  const boneBar = document.getElementById("boneBar");
  const organVal = document.getElementById("organVal");
  const organBar = document.getElementById("organBar");
  const brainVal = document.getElementById("brainVal");
  const brainBar = document.getElementById("brainBar");

  function updateTissue(label: HTMLElement | null, bar: HTMLElement | null, percentage: number) {
    if (label) label.textContent = `${percentage}%`;
    if (bar) bar.style.width = `${percentage}%`;
  }

  function update() {
    if (!ageInput) return;
    const age = parseInt(ageInput.value);
    if (ageDisplay) ageDisplay.textContent = age.toString();

    const result = CellularRenewalEngine.calculate(age);

    if (newStatVal) newStatVal.textContent = result.total.toString();

    updateTissue(skinVal, skinBar, result.skin);
    updateTissue(boneVal, boneBar, result.bone);
    updateTissue(organVal, organBar, result.organ);
    updateTissue(brainVal, brainBar, result.brain);
  }

  ageInput?.addEventListener("input", update);
  update();
</script>
